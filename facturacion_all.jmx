          <hashTree/>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">// Atomic block reservation: getAndAdd is one indivisible op, so no two
// threads can ever reserve overlapping sap_id ranges.
def atom = props.get(&apos;sap_id_atomic&apos;) as java.util.concurrent.atomic.AtomicLong
def batchSize = 8

long first = atom.getAndAdd(batchSize)

for (int i = 0; i &lt; batchSize; i++) {
    vars.put(&apos;sap_id_&apos; + (i + 1), String.valueOf(first + i))
}

log.info(&quot;Thread &quot; + ctx.getThreadNum() + &quot; reserved sap_id block: &quot; + first + &quot;..&quot; + (first + batchSize - 1))

// Set send_date to current ISO timestamp (one value per request)
vars.put(&apos;send_date&apos;, java.time.LocalDateTime.now().toString())</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PreProcessor>
