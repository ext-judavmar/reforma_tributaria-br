          <hashTree/>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">// [SAP_ID v2] Atomically reserve a unique block of sap_ids for this iteration.
// AtomicLong.getAndAdd is thread-safe: every concurrent thread receives a
// disjoint range, so sap_id values never repeat across users or
// iterations and the counter advances strictly monotonically.
import java.util.concurrent.atomic.AtomicLong

def counter = (AtomicLong) props.get(&apos;sap_id_atomic&apos;)
if (counter == null) {
    throw new IllegalStateException(&quot;[SAP_ID v2] sap_id_atomic not initialized â€” init sampler did not run.&quot;)
}
def batchSize = 4
def startSapId = counter.getAndAdd(batchSize)

for (int i = 0; i &lt; batchSize; i++) {
    vars.put(&quot;sap_id_&quot; + (i + 1), (startSapId + i).toString())
}

log.info(&quot;Reserved sap_id block: &quot; + startSapId + &quot;..&quot; + (startSapId + batchSize - 1))

// Set send_date to current ISO timestamp (one value per request)
vars.put(&apos;send_date&apos;, java.time.LocalDateTime.now().toString())</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
      </hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="UAT RTArg - Thread Group">
        <stringProp name="ThreadGroup.num_threads">${virtualUsers}</stringProp>
        <stringProp name="ThreadGroup.ramp_time">${rampUp}</stringProp>
        <stringProp name="ThreadGroup.duration">${testTime}</stringProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">false</boolProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">${loopCount_ar}</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
        <OnceOnlyController guiclass="OnceOnlyControllerGui" testclass="OnceOnlyController" testname="Once Only Controller"/>
        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="JSR223 Sampler" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">// Initialize an AtomicLong-backed counter so sap_id reservation is atomic across VUs.
// OnceOnlyController runs once PER THREAD, so multiple threads enter this block.
// The synchronized check-and-put guarantees that exactly one AtomicLong is created
// and shared across all threads, so the counter is never reset mid-test and ids never repeat.
import java.util.concurrent.atomic.AtomicLong

def initialSapId = vars.get(&apos;initialSapId&apos;).toLong()
synchronized (props) {
    if (props.get(&apos;sap_id_atomic&apos;) == null) {
        props.put(&apos;sap_id_atomic&apos;, new AtomicLong(initialSapId))
        log.info(&quot;Initialized sap_id_atomic to: &quot; + initialSapId)
    } else {
        log.info(&quot;sap_id_atomic already initialized, current=&quot; + ((AtomicLong) props.get(&apos;sap_id_atomic&apos;)).get())
    }
}</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223Sampler>
          <hashTree/>
        </hashTree>
