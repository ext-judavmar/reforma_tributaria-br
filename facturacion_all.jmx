      <hashTree>
        <OnceOnlyController guiclass="OnceOnlyControllerGui" testclass="OnceOnlyController" testname="Once Only Controller" enabled="true"/>
        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="JSR223 Sampler" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">// [SAP_ID v2] Thread-safe global counter for sap_id.
// OnceOnlyController runs once PER THREAD, so multiple threads enter this
// block. The synchronized check-and-put guarantees that exactly one
// AtomicLong is created and shared across all threads, so the counter
// is never reset mid-test and ids never repeat.
import java.util.concurrent.atomic.AtomicLong

def initialSapId = vars.get(&apos;initialSapId&apos;).toLong()
synchronized (props) {
    if (props.get(&apos;sap_id_atomic&apos;) == null) {
        props.put(&apos;sap_id_atomic&apos;, new AtomicLong(initialSapId))
        log.info(&quot;[SAP_ID v2] Created sap_id_atomic starting at &quot; + initialSapId)
    } else {
        def existing = ((AtomicLong) props.get(&apos;sap_id_atomic&apos;)).get()
        log.info(&quot;[SAP_ID v2] Counter already initialized, current=&quot; + existing)
    }
}
log.info(&quot;Initialized sap_id_atomic to: &quot; + initialSapId)</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223Sampler>
          <hashTree/>
        </hashTree>
